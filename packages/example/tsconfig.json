{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@lynx-js/react",

    "module": "node18",
    "moduleResolution": "node16",

    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "tamer-router/generated-routes": ["node_modules/.tamer-router/_generated_routes.tsx"]
    }
  },
  "include": ["intrinsic-element.d.ts", "src/**/*", "lynx.config.ts"],
  "exclude": ["dist/"]
}
